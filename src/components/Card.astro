---
// Card component - reusable container with white background, border, shadow, and padding variants
// Responsive padding: smaller on mobile, larger on desktop

interface Props {
  variant?: 'default' | 'transparent';
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
}

const {
  variant = 'default',
  padding = 'md',
  hover = true,
  class: className = ''
} = Astro.props;

const baseClasses = 'rounded-xl border border-[--color-border-light] transition-shadow';

const variantClasses = {
  default: 'bg-white',
  transparent: 'bg-transparent'
};

// Responsive padding classes - smaller on mobile, larger on desktop
const paddingClasses = {
  sm: 'p-3 md:p-4',
  md: 'p-4 md:p-6',
  lg: 'p-6 md:p-8'
};

const hoverClass = hover ? 'hover:shadow-md' : '';

const classes = [
  baseClasses,
  variantClasses[variant],
  paddingClasses[padding],
  hoverClass,
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
